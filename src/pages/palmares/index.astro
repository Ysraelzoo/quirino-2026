---

<Page
  title="Palmarés — Premios Quirino"
  description="Palmarés histórico de los Premios Quirino de la Animación Iberoamericana. Todos los ganadores desde la primera edición en 2018."
  lang={lang}
>

  <!-- ── Header oscuro ── -->
  <section class="palm-hero" id="hero">
    <div class="ph-inner">
      <div>
        <div class="ph-label">Premios Quirino · 2018 – 2025</div>
        <h1 class="ph-title">Palmarés</h1>
      </div>
      <p class="ph-sub">
        Registro histórico de todos los ganadores de los Premios Quirino
        de la Animación Iberoamericana desde la primera edición.
      </p>
    </div>

    <!-- Selector de año -->
    <nav class="year-nav" aria-label="Seleccionar edición">
      {years.map((year, i) => (
        <button
          class={`year-btn${i === 0 ? ' year-btn--on' : ''}`}
          data-year={year}
          aria-pressed={i === 0 ? 'true' : 'false'}
        >
          {year}
        </button>
      ))}
    </nav>
  </section>

  <!-- ── Paneles de ganadores ── -->
  <div class="palm-panels">
    {historialFallback.map((ed, i) => (
      <section
        class={`palm-panel${i === 0 ? ' palm-panel--on' : ''}`}
        data-year={ed.year}
        aria-hidden={i === 0 ? 'false' : 'true'}
      >
        <!-- Cabecera edición -->
        <div class="ed-header">
          <div class="ed-header-left">
            <span class="ed-num">{ed.numero} edición</span>
            <span class="ed-sede">{ed.sede}</span>
          </div>
          <a class="ed-link" href={`/premios/${ed.year}`}>
            Ver edición completa →
          </a>
        </div>

        <!-- Tabla ganadores -->
        <div class="winners-table" role="table" aria-label={`Ganadores ${ed.year}`}>
          <div class="winners-head" role="row">
            <span class="w-th" role="columnheader">Categoría</span>
            <span class="w-th" role="columnheader">Obra ganadora</span>
            <span class="w-th w-th-r" role="columnheader">País · Estudio</span>
          </div>

          {ed.ganadores.map((g: any) => {
            // Soporta datos Sanity (tituloObra i18n + productora)
            // y placeholders legacy (obra + estudio)
            const titulo = g.tituloObra?.[lang] || g.tituloObra?.es || g.obra || '';
            const credito = g.productora || (g.estudio !== '—' && g.estudio !== '---' ? g.estudio : '');
            return (
              <div class="winner-row" role="row">
                <span class="w-cat">{g.categoria}</span>
                <div class="w-obra-wrap">
                  <span class="w-obra">{titulo}</span>
                  {credito && <span class="w-prod">{credito}</span>}
                </div>
                <span class="w-meta">
                  {g.pais}{g.director ? ` · ${g.director}` : ''}
                </span>
              </div>
            );
          })}
        </div>
      </section>
    ))}
  </div>

</Page>

<style>
/* ── Hero ── */
.palm-hero {
  background: var(--ink);
  padding: 160px var(--gutter) 0;
  display: flex;
  flex-direction: column;
  gap: 60px;
}

.ph-inner {
  display: grid;
  grid-template-columns: 1fr 440px;
  gap: 80px;
  align-items: end;
}

.ph-label {
  font-size: 11px; font-weight: 300;
  color: rgba(250,249,247,.3); letter-spacing: .6px;
  margin-bottom: 24px;
}

.ph-title {
  font-size: clamp(64px, 9vw, 118px);
  font-weight: 700;
  color: #fff;
  line-height: 0.92;
  letter-spacing: -3px;
  text-transform: uppercase;
}

.ph-sub {
  font-size: 14px; font-weight: 300;
  color: rgba(250,249,247,.4);
  line-height: 1.85; align-self: end;
}

/* ── Selector de año ── */
.year-nav {
  display: flex;
  gap: 0;
  border-top: 1px solid rgba(255,255,255,.08);
  overflow-x: auto;
}

.year-btn {
  font-size: 13px; font-weight: 400;
  color: rgba(250,249,247,.3);
  padding: 20px 28px;
  border-right: 1px solid rgba(255,255,255,.08);
  cursor: pointer;
  transition: color .15s, background .15s;
  font-family: var(--sans);
  white-space: nowrap;
  letter-spacing: -.2px;
}
.year-btn:first-child { padding-left: 0; border-left: none; }
.year-btn:hover { color: rgba(250,249,247,.7); }
.year-btn--on {
  color: #fff;
  font-weight: 500;
}

/* ── Paneles ── */
.palm-panels {
  padding: 0 var(--gutter) var(--section-v);
}

.palm-panel {
  display: none;
  padding-top: 64px;
}
.palm-panel--on { display: block; }

/* ── Cabecera edición ── */
.ed-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 48px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--line);
}

.ed-header-left {
  display: flex;
  gap: 24px;
  align-items: baseline;
}

.ed-num {
  font-size: 28px; font-weight: 700;
  color: var(--text); letter-spacing: -.5px;
}

.ed-sede {
  font-size: 12px; font-weight: 300;
  color: var(--muted);
}

.ed-link {
  font-size: 11px; font-weight: 400;
  color: var(--gold);
  border-bottom: 1px solid rgba(184,134,42,.3);
  padding-bottom: 2px;
  transition: border-color .15s;
}
.ed-link:hover { border-color: var(--gold); }

/* ── Tabla ganadores ── */
.winners-table {
  border-top: 1px solid var(--line);
}

.winners-head {
  display: grid;
  grid-template-columns: 300px 1fr 260px;
  gap: 40px;
  padding: 10px 0;
  border-bottom: 1px solid var(--line);
}

.w-th {
  font-size: 10px; font-weight: 400;
  color: var(--muted); letter-spacing: .5px;
}
.w-th-r { text-align: right; }

.winner-row {
  display: grid;
  grid-template-columns: 300px 1fr 260px;
  gap: 40px;
  padding: 22px 0;
  border-bottom: 1px solid var(--line);
  align-items: start;
  transition: opacity .15s;
}
.winner-row:hover { opacity: .5; }

.w-cat {
  font-size: 11px; font-weight: 400;
  color: var(--gold); letter-spacing: .1px;
  padding-top: 3px;
}

.w-obra-wrap { display: flex; flex-direction: column; gap: 4px; }

.w-obra {
  font-size: 18px; font-weight: 400;
  color: var(--text); letter-spacing: -.15px;
  line-height: 1.2;
}

.w-prod {
  font-size: 11px; font-weight: 300;
  color: var(--muted);
}

.w-meta {
  font-size: 12px; font-weight: 300;
  color: var(--muted);
  text-align: right; padding-top: 3px;
}

@media (max-width: 768px) {
  .palm-hero {
    padding: 120px var(--gutter) 0;
    gap: 40px;
  }

  .ph-inner {
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .year-nav {
    gap: 0;
    -webkit-overflow-scrolling: touch;
  }

  .year-btn {
    font-size: 12px;
    padding: 16px 18px;
  }

  .palm-panel {
    padding-top: 40px;
  }

  .ed-header {
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
    margin-bottom: 32px;
  }

  .ed-num { font-size: 22px; }

  .winners-head { display: none; }

  .winner-row {
    grid-template-columns: 1fr;
    gap: 6px;
    padding: 16px 0;
  }

  .w-meta {
    text-align: left;
  }

  .w-obra { font-size: 16px; }
}
</style>

<script>
const btns = document.querySelectorAll<HTMLButtonElement>('.year-btn');
const panels = document.querySelectorAll<HTMLElement>('.palm-panel');

btns.forEach(btn => {
  btn.addEventListener('click', () => {
    const year = btn.dataset.year;

    btns.forEach(b => {
      b.classList.remove('year-btn--on');
      b.setAttribute('aria-pressed', 'false');
    });
    btn.classList.add('year-btn--on');
    btn.setAttribute('aria-pressed', 'true');

    panels.forEach(p => {
      if (p.dataset.year === year) {
        p.classList.add('palm-panel--on');
        p.setAttribute('aria-hidden', 'false');
      } else {
        p.classList.remove('palm-panel--on');
        p.setAttribute('aria-hidden', 'true');
      }
    });
  });
});
</script>
