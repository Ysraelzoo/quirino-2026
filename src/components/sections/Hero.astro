---
// src/components/sections/Hero.astro
import { useTranslations, type Lang } from '../../lib/i18n';
import { urlFor } from '../../lib/sanity';

interface Edicion {
  year: number;
  numero: number;
  sede: string;
  heroImage?: any;
}

interface Props {
  edicionActual: Edicion;
  ediciones: Edicion[];
  lang?: Lang;
}

const { edicionActual, ediciones, lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const heroImageUrl = edicionActual.heroImage
  ? urlFor(edicionActual.heroImage).width(1920).height(1080).auto('format').url()
  : null;
---

<section class="hero" id="hero">

  <!-- Foto de fondo -->
  <div
    class="hero-photo"
    style={heroImageUrl ? `background-image: url('${heroImageUrl}')` : ''}
    aria-hidden="true"
  ></div>

  <!-- Contenido principal -->
  <div class="hero-content">

    <!-- Título grande en la parte superior -->
    <div class="hero-title-block">
      <h1 class="hero-title">Premios<br>Quirino</h1>
      <p class="hero-tagline">
        {edicionActual.numero}ª Edición · Animación Iberoamericana
      </p>
    </div>

    <!-- Barra inferior con info + lista de ediciones -->
    <div class="hero-bottom">

      <div class="hb-left">
        <span class="hb-sede">{edicionActual.sede}</span>
        <a class="hb-scroll" href="#categorias">↓ Scroll to explore</a>
      </div>

      <div class="hb-right">
        <div class="hb-table-head">
          <span class="hb-th">{t('col.edicion')}</span>
          <span class="hb-th">{t('col.sede')}</span>
        </div>

        {ediciones.map((ed) => (
          <a
            class:list={['hb-row', { featured: ed.year === edicionActual.year }]}
            href={`/premios/${ed.year}`}
          >
            <span class="hb-year">{ed.year}</span>
            <span class="hb-name">
              {ed.numero}ª · {ed.sede.split(',')[0]}
              {ed.year === edicionActual.year && (
                <span class="hb-active"> — {t('edicion.activa')}</span>
              )}
            </span>
          </a>
        ))}
      </div>

    </div>
  </div>

</section>

<style>
.hero {
  position: relative;
  height: 100vh;
  min-height: 640px;
  overflow: hidden;
  background: var(--ink);
}

.hero-photo {
  position: absolute; inset: 0;
  background-size: cover;
  background-position: center;
  background-color: var(--ink);
  background-image:
    linear-gradient(180deg,
      rgba(0,0,0,.25) 0%,
      rgba(0,0,0,.05) 35%,
      rgba(0,0,0,.55) 70%,
      rgba(0,0,0,.93) 100%
    );
}

/* Capa extra de oscuridad */
.hero-photo::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(180deg,
    rgba(0,0,0,.1)  0%,
    rgba(0,0,0,0)   30%,
    rgba(0,0,0,.45) 68%,
    rgba(0,0,0,.88) 100%
  );
}

/* ── Contenido ── */
.hero-content {
  position: relative; z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 0 var(--gutter);
}

/* ── Título grande ── */
.hero-title-block {
  padding-top: 120px;
  animation: fadeUp .8s ease .1s both;
}

.hero-title {
  font-size: clamp(64px, 9vw, 118px);
  font-weight: 700;
  color: #fff;
  line-height: 0.92;
  letter-spacing: -3px;
  text-transform: uppercase;
  margin-bottom: 22px;
}

.hero-tagline {
  font-size: 12px;
  font-weight: 300;
  color: rgba(250,249,247,.38);
  letter-spacing: .3px;
}

/* ── Barra inferior ── */
.hero-bottom {
  display: grid;
  grid-template-columns: 300px 1fr;
  gap: 80px;
  align-items: end;
  padding: 40px var(--gutter) 48px;
  margin: 0 calc(var(--gutter) * -1);
  animation: fadeUp .7s ease .25s both;
}

.hb-left {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.hb-sede {
  font-size: 11px;
  font-weight: 300;
  color: rgba(250,249,247,.32);
  line-height: 1.6;
}

.hb-scroll {
  font-size: 10px;
  font-weight: 400;
  color: rgba(250,249,247,.22);
  letter-spacing: .5px;
  transition: color .2s;
}
.hb-scroll:hover { color: rgba(250,249,247,.55); }

/* ── Tabla ediciones ── */
.hb-table-head {
  display: grid; grid-template-columns: 72px 1fr;
  padding-bottom: 10px;
  border-bottom: 1px solid rgba(255,255,255,.07);
}

.hb-th {
  font-size: 10px; font-weight: 400;
  color: rgba(250,249,247,.2); letter-spacing: .8px;
}

.hb-row {
  display: grid; grid-template-columns: 72px 1fr;
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,.04);
  transition: opacity .15s;
}
.hb-row:hover { opacity: .55; }
.hb-row.featured { padding: 13px 0; }
.hb-row.featured:hover { opacity: 1; }

.hb-year {
  font-size: 12px; font-weight: 400;
  color: rgba(250,249,247,.25); align-self: center;
}
.hb-row.featured .hb-year { color: var(--gold); }

.hb-name {
  font-size: 12px; font-weight: 400;
  color: rgba(250,249,247,.48); align-self: center;
}
.hb-row.featured .hb-name { font-size: 13px; font-weight: 500; color: rgba(250,249,247,.82); }

.hb-active { font-size: 11px; font-weight: 300; color: var(--gold); opacity: .75; }
</style>
