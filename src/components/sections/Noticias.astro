---
// src/components/sections/Noticias.astro
import { useTranslations, type Lang, t as tField } from '../../lib/i18n';

interface Noticia {
  _id: string;
  titulo: { es: string; pt: string; en: string };
  extracto: { es: string; pt: string; en: string };
  slug: { current: string };
  categoria: string;
  fecha: string;
}

interface Props {
  noticias: Noticia[];
  lang?: Lang;
}

const { noticias, lang = 'es' } = Astro.props;
const t = useTranslations(lang);

function formatFecha(fecha: string, lang: Lang) {
  return new Date(fecha).toLocaleDateString(
    lang === 'pt' ? 'pt-PT' : lang === 'en' ? 'en-GB' : 'es-ES',
    { day: 'numeric', month: 'short', year: 'numeric' }
  );
}
---

<section class="noticias reveal" id="prensa">
  <div class="news-header">
    <h2 class="news-h-title">Novedades</h2>
    <div class="news-h-right">
      <a class="news-h-link" href="/prensa">{t('news.verTodas')}</a>
    </div>
  </div>

  <div class="news-table" role="table" aria-label="Últimas noticias">
    <div class="news-table-head" role="row">
      <span class="news-th" role="columnheader">{t('col.fecha')}</span>
      <span class="news-th" role="columnheader">{t('col.area')}</span>
      <span class="news-th" role="columnheader">{t('col.noticia')}</span>
    </div>

    {noticias.map((n) => (
      <a class="news-row" href={`/prensa/${n.slug.current}`} role="row">
        <time class="news-date" datetime={n.fecha}>{formatFecha(n.fecha, lang)}</time>
        <span class="news-cat">{n.categoria}</span>
        <div>
          <h3 class="news-title">{n.titulo[lang] || n.titulo.es}</h3>
          <p class="news-body">{n.extracto[lang] || n.extracto.es}</p>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
.noticias {
  padding: 0 var(--gutter) var(--section-v);
  border-top: 1px solid var(--line);
}

.news-header {
  display: grid; grid-template-columns: 1fr 340px;
  gap: 80px; padding-top: 80px; margin-bottom: 56px; align-items: end;
}

.news-h-title {
  font-size: clamp(52px, 5.5vw, 80px); font-weight: 700; color: var(--text);
  line-height: 0.93; letter-spacing: -2px; text-transform: uppercase;
}

.news-h-right {
  display: flex; align-items: flex-end; justify-content: flex-end;
}

.news-h-link {
  font-size: 11px; font-weight: 400; color: var(--muted);
  border-bottom: 1px solid var(--line); padding-bottom: 1px;
  transition: color .15s, border-color .15s;
}
.news-h-link:hover { color: var(--text); border-color: var(--text); }

.news-table { border-top: 1px solid var(--line); }

.news-table-head {
  display: grid; grid-template-columns: 160px 100px 1fr;
  gap: 40px; padding: 10px 0; border-bottom: 1px solid var(--line);
}

.news-th { font-size: 10px; font-weight: 400; color: var(--muted); letter-spacing: .5px; }

.news-row {
  display: grid; grid-template-columns: 160px 100px 1fr;
  gap: 40px; padding: 24px 0; border-bottom: 1px solid var(--line);
  cursor: pointer; align-items: start; transition: opacity .15s;
}
.news-row:hover { opacity: .5; }

.news-date { font-size: 12px; font-weight: 300; color: var(--muted); padding-top: 2px; }
.news-cat  { font-size: 11px; font-weight: 400; color: var(--muted); padding-top: 2px; }

.news-title {
  font-size: 16px; font-weight: 400; color: var(--text);
  line-height: 1.3; letter-spacing: -.1px; margin-bottom: 6px;
}

.news-body {
  font-size: 12px; font-weight: 300; color: var(--muted);
  line-height: 1.75; max-width: 520px;
}
</style>
